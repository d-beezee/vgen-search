<!DOCTYPE html>
<html lang="it">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>VGen - Commissioni Artisti</title>
    <link rel="stylesheet" href="/styles.css">
</head>
<body>
    <div class="container">
        <header>
            <h1>🎨 VGen Commission Services</h1>
            <p>Cerca artisti disponibili per commissioni</p>
        </header>

        <section class="search-section">
            <div class="search-controls">
                <div class="search-group">
                    <label>Categoria:</label>
                    <div class="category-buttons">
                        <button class="category-btn active" onclick="filterByCategory('')">Tutte</button>
                        <button class="category-btn" onclick="filterByCategory('recSUfZT4cF56dTpN')">Reference Sheet</button>
                        <button class="category-btn" onclick="filterByCategory('recmgzrPpwLaQYP0p')">Illustrations</button>
                    </div>
                </div>

                <div class="search-group">
                    <label>Filtri:</label>
                    <div class="special-filter-buttons">
                        <button class="special-filter-btn" onclick="filterBySpecialStyle('Semi-Realistic Illustration')">Semi-Realistic</button>
                        <button class="special-filter-btn" onclick="filterBySpecialStyle('Emotes')">Emotes</button>
                    </div>
                </div>
                
                <div class="search-group">
                    <label for="sortType">Ordina per:</label>
                    <select id="sortType" onchange="handleSearch()">
                        <option value="relevance">Rilevanza</option>
                        <option value="newest">Più recenti</option>
                        <option value="popular">Più popolari</option>
                    </select>
                </div>
                
                <div class="search-group">
                    <label for="minPrice">Prezzo minimo (€):</label>
                    <input type="number" id="minPrice" min="0" step="10" value="0" placeholder="Min" onchange="handleSearch()">
                </div>
                
                <div class="search-group">
                    <label for="maxPrice">Prezzo massimo (€):</label>
                    <input type="number" id="maxPrice" min="0" step="10" value="10000" placeholder="Max" onchange="handleSearch()">
                </div>
                
                <div class="search-group checkbox-group">
                    <label for="onSaleCheckbox">
                        <input type="checkbox" id="onSaleCheckbox" onchange="handleSearch()">
                        <span>In offerta</span>
                    </label>
                </div>
                
                <button class="btn-primary" onclick="handleSearch()">🔍 Cerca</button>
            </div>
        </section>

        <section class="results-section">
            <div id="loading" class="loading hidden">
                <div class="spinner"></div>
                <p>Caricamento...</p>
            </div>

            <div id="error" class="error hidden"></div>

            <div id="results" class="results-grid">
                <div class="no-results">
                    <p>Nessun risultato. Clicca su "Cerca" per iniziare!</p>
                </div>
            </div>

            <div id="loadMoreContainer" class="load-more-container hidden">
                <button class="btn-primary" onclick="loadMore()">Carica altri risultati</button>
            </div>
        </section>
    </div>

    <script src="/app.js"></script>
</body>
</html>
